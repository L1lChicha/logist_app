<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="logist_app.EditClientPage"
             Title="Edit Client"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1a1a1a}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="PrimaryColor">#007ACC</Color>
            <Color x:Key="PrimaryColorDark">#5AAFFF</Color>
            <Color x:Key="SuccessColor">#1E8E3E</Color>
            <Color x:Key="SuccessColorDark">#4ADE80</Color>
            <Color x:Key="DestructiveColor">#D93025</Color>
            <Color x:Key="DestructiveColorDark">#F87171</Color>

            <Style x:Key="InputBorderStyle" TargetType="Border">
                <Setter Property="Stroke" Value="{AppThemeBinding Light=#E0E0E0, Dark=#404040}"/>
                <Setter Property="StrokeThickness" Value="1"/>
                <Setter Property="StrokeShape" Value="RoundRectangle 8"/>
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=White, Dark=#2d2d2d}"/>
                <Setter Property="Padding" Value="10,0"/>
                <Setter Property="HeightRequest" Value="45"/>
            </Style>

            <Style x:Key="FormLabelStyle" TargetType="Label">
                <Setter Property="TextColor" Value="{AppThemeBinding Light=#1F1F1F, Dark=#E0E0E0}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="Margin" Value="0,0,0,5"/>
            </Style>

            <Style x:Key="FormEntryStyle" TargetType="Entry">
                <Setter Property="TextColor" Value="{AppThemeBinding Light=Black, Dark=#E0E0E0}"/>
                <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light=#9CA3AF, Dark=#666}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="BackgroundColor" Value="Transparent"/>
                <Setter Property="VerticalOptions" Value="Center"/>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <Grid RowDefinitions="Auto, *" Padding="20">
            
            <Border Grid.Row="0"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#2d2d2d}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 15"
                    WidthRequest="1000" 
                    HorizontalOptions="Center">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="{AppThemeBinding Light=0.05, Dark=0.2}"/>
                </Border.Shadow>

                <VerticalStackLayout Padding="25" Spacing="20">

                    <Label Text="Edit Client Details" 
                           FontSize="22" 
                           TextColor="{AppThemeBinding Light=#1F1F1F, Dark=#E0E0E0}"
                           HorizontalOptions="Center"
                           Margin="0,0,0,10"/>

                    <VerticalStackLayout Spacing="0">
                        <Label Text="Client Name" Style="{StaticResource FormLabelStyle}"/>
                        <Border Style="{StaticResource InputBorderStyle}">
                            <Entry Text="{Binding Client.Name}" Placeholder="Company or Name" Style="{StaticResource FormEntryStyle}"/>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="0">
                        <Label Text="Address" Style="{StaticResource FormLabelStyle}"/>
                        <Border Style="{StaticResource InputBorderStyle}">
                            <Entry Text="{Binding Client.Address}" Placeholder="Street Address" Style="{StaticResource FormEntryStyle}"/>
                        </Border>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*, 0.5*" ColumnSpacing="15">
                        <VerticalStackLayout Grid.Column="0" Spacing="0">
                            <Label Text="City" Style="{StaticResource FormLabelStyle}"/>
                            <Border Style="{StaticResource InputBorderStyle}">
                                <Entry Text="{Binding Client.City}" Placeholder="City" Style="{StaticResource FormEntryStyle}"/>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="0">
                            <Label Text="Postal Code" Style="{StaticResource FormLabelStyle}"/>
                            <Border Style="{StaticResource InputBorderStyle}">
                                <Entry Text="{Binding Client.PostalCode}" Placeholder="Zip" Keyboard="Numeric" Style="{StaticResource FormEntryStyle}"/>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                        <VerticalStackLayout Grid.Column="0" Spacing="0">
                            <Label Text="Phone" Style="{StaticResource FormLabelStyle}"/>
                            <Border Style="{StaticResource InputBorderStyle}">
                                <Entry Text="{Binding Client.Phone}" Placeholder="+1..." Keyboard="Telephone" Style="{StaticResource FormEntryStyle}"/>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="0">
                            <Label Text="Email" Style="{StaticResource FormLabelStyle}"/>
                            <Border Style="{StaticResource InputBorderStyle}">
                                <Entry Text="{Binding Client.Email}" Placeholder="name@example.com" Keyboard="Email" Style="{StaticResource FormEntryStyle}"/>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#F0F0F0, Dark=#404040}" Margin="0,5"/>

                    <Label Text="Logistics &amp; Schedule" FontSize="16" TextColor="{AppThemeBinding Light={StaticResource PrimaryColor}, Dark={StaticResource PrimaryColorDark}}"/>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                        <VerticalStackLayout Grid.Column="0" Spacing="0">
                            <Label Text="Container Count" Style="{StaticResource FormLabelStyle}"/>
                            <Border Style="{StaticResource InputBorderStyle}">
                                <Entry Text="{Binding Client.ContainerCount}" Keyboard="Numeric" Style="{StaticResource FormEntryStyle}"/>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="0">
                            <Label Text="Start Date" Style="{StaticResource FormLabelStyle}"/>
                            <Border Style="{StaticResource InputBorderStyle}">
                                <DatePicker Date="{Binding Client.StartDate}" TextColor="{AppThemeBinding Light=Black, Dark=#E0E0E0}"/>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Recurrence Rule" Style="{StaticResource FormLabelStyle}"/>
                        <Button Text="Configure Schedule" 
                                Command="{Binding ConfigureRecurrenceCommand}" 
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#2d2d2d}" 
                                TextColor="{AppThemeBinding Light=#1F1F1F, Dark=#E0E0E0}"
                                BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#404040}"
                                BorderWidth="1"
                                CornerRadius="8"
                                HeightRequest="45"
                                HorizontalOptions="Fill"/>
                        <Label Text="{Binding RecurrenceSummary}" 
                               TextColor="{AppThemeBinding Light=#757575, Dark=#888888}" 
                               FontSize="12"
                               Margin="5,0,0,0"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="10" Margin="0,15,0,0">
                        
                        <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                            <Button x:Name="cancelButton" 
                                    Grid.Column="0"
                                    Text="Cancel" 
                                    Command="{Binding CancelCommand}" 
                                    BackgroundColor="{AppThemeBinding Light=White, Dark=#2d2d2d}" 
                                    TextColor="{AppThemeBinding Light=#1F1F1F, Dark=#E0E0E0}"
                                    BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#404040}"
                                    BorderWidth="1"
                                    CornerRadius="10"
                                    HeightRequest="50"
                                    FontAttributes="Bold"/>

                            <Button x:Name="saveButton" 
                                    Grid.Column="1"
                                    Text="Save Changes" 
                                    Command="{Binding SaveClientCommand}" 
                                    BackgroundColor="{AppThemeBinding Light={StaticResource SuccessColor}, Dark={StaticResource SuccessColorDark}}" 
                                    TextColor="{AppThemeBinding Light=White, Dark=#1a1a1a}"
                                    CornerRadius="10"
                                    HeightRequest="50"
                                    FontAttributes="Bold"/>
                        </Grid>

                        <Button x:Name="deleteClientButton" 
                                Text="Delete Client" 
                                Command="{Binding DeleteClientCommand}" 
                                BackgroundColor="{AppThemeBinding Light=#FCE8E6, Dark=#4d2626}" 
                                TextColor="{AppThemeBinding Light={StaticResource DestructiveColor}, Dark={StaticResource DestructiveColorDark}}"
                                CornerRadius="10"
                                HeightRequest="45"
                                Margin="0,10,0,0"/>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>
