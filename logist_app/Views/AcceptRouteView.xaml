<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="logist_app.Views.AcceptRouteView"
             Title="View Route"
             BackgroundColor="#F5F5F5">

    <Grid ColumnDefinitions="380, *" RowDefinitions="*">

        <Border Grid.Column="0" 
                BackgroundColor="White" 
                StrokeThickness="0"
                Padding="25">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="2,0" Radius="10" Opacity="0.1"/>
            </Border.Shadow>

            <VerticalStackLayout Spacing="25" VerticalOptions="Center">

                <Label Text="Route Actions" 
                       FontSize="20" 
                       FontAttributes="Bold" 
                       TextColor="#333"
                       HorizontalOptions="Center"
                       Margin="0,0,0,20"/>

                <Border Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="15,5">
                    <Entry x:Name="RouteNameEntry" 
                           Placeholder="Enter route name"
                           FontSize="16"
                           TextColor="#333"
                           PlaceholderColor="#999"
                           HorizontalTextAlignment="Center"
                           Text="{Binding RouteName}" />
                </Border>

                <VerticalStackLayout Spacing="15">

                    <Button Text="Edit"
                            x:Name="editRoute"
                            Clicked="EditRoute_Clicked"
                            BackgroundColor="#F0F0F0"
                            TextColor="#333"
                            CornerRadius="10"
                            HeightRequest="55"
                            FontAttributes="Bold"/>

                    <Button Text="Reject"
                            x:Name="rejectRoute"
                            Command="{Binding RejectRouteCommand}"
                            BackgroundColor="#FCE8E6"
                            TextColor="#D93025"
                            CornerRadius="10"
                            HeightRequest="55"
                            FontAttributes="Bold"/>
                </VerticalStackLayout>

                <BoxView HeightRequest="1" Color="#E0E0E0" Margin="0,10"/>

                <Button Text="Confirm Route"
                        x:Name="confirmRoute"
                        Clicked="ConfirmRoute_Clicked"
                        BackgroundColor="#1E8E3E"
                        TextColor="White"
                        CornerRadius="12"
                        HeightRequest="65"
                        FontSize="16"
                        FontAttributes="Bold"
                        Shadow="{Shadow Brush=Black, Offset='0,4', Radius=8, Opacity=0.2}"/>

            </VerticalStackLayout>
        </Border>

        <Border Grid.Column="1" 
                Margin="20" 
                StrokeShape="RoundRectangle 20" 
                StrokeThickness="0"
                BackgroundColor="White">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="15" Opacity="0.1"/>
            </Border.Shadow>

            <WebView x:Name="MapWebView" 
                     Source="map.html" 
                     Navigated="MapWebView_Navigated"
                     HorizontalOptions="Fill"
                     VerticalOptions="Fill"/>
        </Border>

    </Grid>
</ContentPage>