<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:entities="clr-namespace:logist_app.Core.Entities"
             x:Class="logist_app.Views.AcceptRouteView"
             Title="View Route"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1a1a1a}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="SuccessColor">#1E8E3E</Color>
            <Color x:Key="SuccessColorDark">#4ADE80</Color>
            <Color x:Key="DestructiveColor">#D93025</Color>
            <Color x:Key="DestructiveColorDark">#F87171</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid ColumnDefinitions="380, *" RowDefinitions="*">

        <Border Grid.Column="0" 
                BackgroundColor="{AppThemeBinding Light=White, Dark=#2d2d2d}" 
                StrokeThickness="0"
                Padding="25">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="2,0" Radius="10" Opacity="{AppThemeBinding Light=0.1, Dark=0.3}"/>
            </Border.Shadow>

            <VerticalStackLayout Spacing="25" VerticalOptions="Center">

                <Label Text="{Binding RouteName}"></Label>

                <Button Text="Показать точки маршрута" 
        x:Name="showRoutePointsButton"
        Command="{Binding ShowRoutePointsCommand}" 
        BackgroundColor="{AppThemeBinding Light=#2196F3, Dark=#3B82F6}"
        TextColor="White"
        CornerRadius="8"
        HeightRequest="45"
        FontAttributes="Bold"/>

                <CollectionView ItemsSource="{Binding DisplayRoutePoints}"
                IsVisible="{Binding IsRoutePointsVisible}"
                MaximumHeightRequest="700"
                Margin="0,10,0,10">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="entities:RoutePoint">
                            <Grid Padding="5,10" ColumnDefinitions="40, *" RowDefinitions="Auto">

                                <Border Grid.Column="0" 
                        BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#404040}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20" 
                        WidthRequest="30" 
                        HeightRequest="30" 
                        HorizontalOptions="Center" 
                        VerticalOptions="Start">
                                    <Label Text="{Binding SequenceNumber}" 
                           HorizontalOptions="Center" 
                           VerticalOptions="Center" 
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#333, Dark=#E0E0E0}"/>
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Padding="10,0,0,0" Spacing="2">
                                    <Label Text="{Binding Client.Name, TargetNullValue='Неизвестный клиент'}" 
                           FontAttributes="Bold" 
                           FontSize="14" 
                           TextColor="{AppThemeBinding Light=#333, Dark=#E0E0E0}" />
                                    <Label Text="{Binding Client.Address, TargetNullValue='Адрес не указан'}" 
                           FontSize="12" 
                           TextColor="{AppThemeBinding Light=#666, Dark=#A0A0A0}" />
                                    <Label Text="{Binding Status}" 
                           FontSize="11" 
                           TextColor="Gray"
                           TextTransform="Uppercase"/>
                                </VerticalStackLayout>

                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>


                    <Entry x:Name="RouteNameEntry" 
                           Placeholder="Enter route name"
                           FontSize="16"
                           TextColor="{AppThemeBinding Light=#333, Dark=#E0E0E0}"
                           PlaceholderColor="{AppThemeBinding Light=#999, Dark=#919294}"
                           HorizontalTextAlignment="Center"
                           Text="{Binding NewRouteName}" />
              

                <VerticalStackLayout Spacing="15">

                    <Button Text="Edit"
                            x:Name="editRoute"
                            Clicked="EditRoute_Clicked"
                            BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#404040}"
                            TextColor="{AppThemeBinding Light=#333, Dark=#E0E0E0}"
                            CornerRadius="10"
                            HeightRequest="55"
                            FontAttributes="Bold"/>

                    <Button Text="Reject"
                            x:Name="rejectRoute"
                            Command="{Binding RejectRouteCommand}"
                            BackgroundColor="{AppThemeBinding Light=#FCE8E6, Dark=#4d2626}"
                            TextColor="{AppThemeBinding Light={StaticResource DestructiveColor}, Dark={StaticResource DestructiveColorDark}}"
                            CornerRadius="10"
                            HeightRequest="55"
                            FontAttributes="Bold"/>
                </VerticalStackLayout>

                <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E0E0E0, Dark=#404040}" Margin="0,10"/>

                <Button Text="Confirm Route"
                        x:Name="confirmRoute"
                        Clicked="ConfirmRoute_Clicked"
                        BackgroundColor="{AppThemeBinding Light={StaticResource SuccessColor}, Dark={StaticResource SuccessColorDark}}"
                        TextColor="{AppThemeBinding Light=White, Dark=#1a1a1a}"
                        CornerRadius="12"
                        HeightRequest="65"
                        FontSize="16"
                        FontAttributes="Bold"
                        Shadow="{Shadow Brush=Black, Offset='0,4', Radius=8, Opacity=0.2}"/>

            </VerticalStackLayout>
        </Border>

        <Border Grid.Column="1" 
                Margin="20" 
                StrokeShape="RoundRectangle 20" 
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#2d2d2d}">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="15" Opacity="{AppThemeBinding Light=0.1, Dark=0.3}"/>
            </Border.Shadow>

            <WebView x:Name="MapWebView" 
                     Source="map.html" 
                     Navigated="MapWebView_Navigated"
                     HorizontalOptions="Fill"
                     VerticalOptions="Fill"/>
        </Border>

    </Grid>
</ContentPage>
