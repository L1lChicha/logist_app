<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="logist_app.Views.ActionPageView"
             Title="Menu"
             BackgroundColor="#F5F5F5">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="PrimaryColor">#007ACC</Color>
            <Color x:Key="TextPrimary">#1F1F1F</Color>

            <Style x:Key="MenuButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="White"/>
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="HeightRequest" Value="60"/>
                <Setter Property="Margin" Value="0,0,0,15"/>
                <Setter Property="Shadow">
                    <Setter.Value>
                        <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.1"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource PrimaryColor}"/>
                <Setter Property="TextColor" Value="White"/>
                <Setter Property="FontSize" Value="17"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="HeightRequest" Value="65"/>
                <Setter Property="Margin" Value="0,0,0,25"/>
                <Setter Property="Shadow">
                    <Setter.Value>
                        <Shadow Brush="{StaticResource PrimaryColor}" Offset="0,4" Radius="8" Opacity="0.3"/>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid ColumnDefinitions="320, *" RowDefinitions="*">

        <Border Grid.Column="0" 
                BackgroundColor="#FAFAFA" 
                StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="2,0" Radius="10" Opacity="0.05"/>
            </Border.Shadow>

            <ScrollView>
                <VerticalStackLayout Padding="20" Spacing="5">

                    <Label Text="Logistic Dashboard"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"
                           Margin="0,20,0,30"
                           HorizontalOptions="Center"/>

                    <Button x:Name="createRoute" 
                            Text="Create Route" 
                            Clicked="createRoute_Clicked"
                            Style="{StaticResource PrimaryButtonStyle}"/>

                    <Label Text="Management" 
                           TextColor="#999" 
                           FontSize="12" 
                           FontAttributes="Bold" 
                           Margin="5,0,0,10"/>

                    <Button x:Name="viewRoutes" 
                            Text="View Routes" 
                            Clicked="viewRoutes_Clicked"
                            Style="{StaticResource MenuButtonStyle}"/>

                    <Button x:Name="showClientsData" 
                            Text="Show Clients Data" 
                            Clicked="showClientsData_Clicked"
                            Style="{StaticResource MenuButtonStyle}"/>

                    <Button x:Name="addNewClient" 
                            Text="Add New Client" 
                            Clicked="addNewClient_Clicked"
                            Style="{StaticResource MenuButtonStyle}"/>

                    <Label Text="Resources" 
                           TextColor="#999" 
                           FontSize="12" 
                           FontAttributes="Bold" 
                           Margin="5,10,0,10"/>

                    <Button x:Name="drivers" 
                            Text="Drivers" 
                            Clicked="drivers_Clicked"
                            Style="{StaticResource MenuButtonStyle}"/>

                    <Button x:Name="vehicles" 
                            Text="Vehicles" 
                            Clicked="vehicles_Clicked"
                            Style="{StaticResource MenuButtonStyle}"
                            Margin="0"/>

                    <Label Text="Settings" 
                           TextColor="#999" 
                           FontSize="12" 
                           FontAttributes="Bold" 
                           Margin="5,10,0,10"/>
                    <Button x:Name="routeSettings" 
                            Text="Route creation settings" 
                            Clicked="routeSettings_Clicked"
                            Style="{StaticResource MenuButtonStyle}"
                            Margin="0"/>
                    <Button x:Name="appSettings" 
                            Text="App settings" 
                            Clicked="appSettings_Clicked"
                            Style="{StaticResource MenuButtonStyle}"
                            Margin="0"/>        
                </VerticalStackLayout>
            </ScrollView>
        </Border>

        <Border Grid.Column="1" 
                Margin="20" 
                StrokeShape="RoundRectangle 20" 
                StrokeThickness="0"
                BackgroundColor="White">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="15" Opacity="0.1"/>
            </Border.Shadow>

            <WebView x:Name="MapWebView" 
                     Source="map.html" 
                     HorizontalOptions="Fill" 
                     VerticalOptions="Fill"/>
        </Border>

    </Grid>
</ContentPage>