<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:logist_app.ViewModels"
             xmlns:converters="clr-namespace:logist_app.Infrastructure.Service"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="logist_app.Views.RouteSettingsView"
             Title="Algorithm Settings"
             BackgroundColor="{AppThemeBinding Light=#F3F3F3, Dark=#121212}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:DoubleToStringConverter x:Key="DoubleToStringConverter"/>
            <toolkit:InvertedBoolConverter x:Key="InverseBoolConverter"/>

            <Color x:Key="BrandColor">#2B0B98</Color>
            <Color x:Key="BrandColorHover">#4020B0</Color>

            <Style x:Key="WinCard" TargetType="Border">
                <Setter Property="Padding" Value="20"/>
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=White, Dark=#1F1F1F}"/>
                <Setter Property="StrokeShape" Value="RoundRectangle 8"/>
                <Setter Property="StrokeThickness" Value="1"/>
                <Setter Property="Stroke" Value="{AppThemeBinding Light=#E5E5E5, Dark=#333}"/>
                <Setter Property="Shadow">
                    <Setter.Value>
                        <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.1"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="Header" TargetType="Label">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="TextColor" Value="{StaticResource BrandColor}"/>
                <Setter Property="Margin" Value="0,0,0,15"/>
            </Style>

            <Style x:Key="FieldText" TargetType="Label">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="TextColor" Value="{AppThemeBinding Light=#555, Dark=#CCC}"/>
                <Setter Property="VerticalOptions" Value="Center"/>
            </Style>

            <Style x:Key="WinInput" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#FAFAFA, Dark=#2A2A2A}"/>
                <Setter Property="Stroke" Value="{AppThemeBinding Light=#D0D0D0, Dark=#444}"/>
                <Setter Property="StrokeThickness" Value="1"/>
                <Setter Property="StrokeShape" Value="RoundRectangle 4"/>
                <Setter Property="HeightRequest" Value="32"/>
                <Setter Property="Padding" Value="8,0"/>
                <Setter Property="VerticalOptions" Value="Center"/>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <ScrollView>
            <Grid Padding="30" RowSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource WinCard}" Margin="0,0,10,0">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="📦 Logistics" Style="{StaticResource Header}"/>

                        <Grid ColumnDefinitions="*, 80" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">

                            <Label Grid.Row="0" Text="Max Points:" Style="{StaticResource FieldText}"/>
                            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource WinInput}">
                                <Entry Text="{Binding MaxPointsQuantity}" Keyboard="Numeric" FontSize="13"/>
                            </Border>

                            <Label Grid.Row="1" Text="Min Points:" Style="{StaticResource FieldText}"/>
                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource WinInput}">
                                <Entry Text="{Binding MinPointsQuantity}" Keyboard="Numeric" FontSize="13"/>
                            </Border>

                            <Label Grid.Row="2" Text="Containers:" Style="{StaticResource FieldText}"/>
                            <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource WinInput}">
                                <Entry Text="{Binding MaxContainersQuantity, Converter={StaticResource DoubleToStringConverter}}" Keyboard="Numeric" FontSize="13"/>
                            </Border>

                            <Label Grid.Row="3" Text="Avg. Speed:" Style="{StaticResource FieldText}"/>
                            <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource WinInput}">
                                <Entry Text="{Binding AverageSpeedKmh, Converter={StaticResource DoubleToStringConverter}}" Keyboard="Numeric" FontSize="13"/>
                            </Border>
                        </Grid>

                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#EEE, Dark=#333}" Margin="0,5"/>

                        <Label Text="📍 Depot Coordinates" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#333, Dark=White}"/>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Border Grid.Column="0" Style="{StaticResource WinInput}">
                                <Entry Placeholder="Lat" Text="{Binding DepotLat, Converter={StaticResource DoubleToStringConverter}}" FontSize="13"/>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource WinInput}">
                                <Entry Placeholder="Lon" Text="{Binding DepotLon, Converter={StaticResource DoubleToStringConverter}}" FontSize="13"/>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource WinCard}" Margin="5,0,5,0">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="🚚 Truck" Style="{StaticResource Header}"/>

                        <Grid ColumnDefinitions="*, 100" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">

                            <Label Grid.Row="0" Text="Vehicle Type:" Style="{StaticResource FieldText}"/>
                            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource WinInput}">
                                <Picker ItemsSource="{Binding VehicleTypes}" 
                                        SelectedItem="{Binding SelectedVehicleType}" 
                                        FontSize="13"
                                        TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                            </Border>

                            <Label Grid.Row="1" Text="Height (m):" Style="{StaticResource FieldText}"/>
                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource WinInput}">
                                <Entry Text="{Binding TruckHeightMeters, Converter={StaticResource DoubleToStringConverter}}" Keyboard="Numeric" FontSize="13"/>
                            </Border>

                            <Label Grid.Row="2" Text="Width (m):" Style="{StaticResource FieldText}"/>
                            <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource WinInput}">
                                <Entry Text="{Binding TruckWidthMeters, Converter={StaticResource DoubleToStringConverter}}" Keyboard="Numeric" FontSize="13"/>
                            </Border>

                            <Label Grid.Row="3" Text="Min Bridge (t):" Style="{StaticResource FieldText}"/>
                            <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource WinInput}">
                                <Entry Text="{Binding MinBridgeWeightTons, Converter={StaticResource DoubleToStringConverter}}" Keyboard="Numeric" FontSize="13"/>
                            </Border>
                        </Grid>

                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#EEE, Dark=#333}" Margin="0,5"/>

                        <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, Auto" RowSpacing="8">
                            <Label Grid.Row="0" Grid.Column="0" Text="Avoid Highways" VerticalOptions="Center" Style="{StaticResource FieldText}"/>
                            <Switch Grid.Row="0" Grid.Column="1" IsToggled="{Binding AvoidHighways}" OnColor="{StaticResource BrandColor}"/>

                            <Label Grid.Row="1" Grid.Column="0" Text="Traffic Signs" VerticalOptions="Center" Style="{StaticResource FieldText}"/>
                            <Switch Grid.Row="1" Grid.Column="1" IsToggled="{Binding UseRealSpeed}" OnColor="{StaticResource BrandColor}"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource WinCard}" Margin="10,0,0,0">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="🧩 Algorithm" Style="{StaticResource Header}"/>

                        <Grid ColumnDefinitions="*, 80" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">

                            <Label Grid.Row="0" Text="2-Opt Iterations:" Style="{StaticResource FieldText}"/>
                            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource WinInput}">
                                <Entry Text="{Binding MaxIterations2Opt}" Keyboard="Numeric" FontSize="13"/>
                            </Border>

                            <Label Grid.Row="1" Text="Search Radius:" Style="{StaticResource FieldText}"/>
                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource WinInput}">
                                <Entry Text="{Binding NeighborSearchRadiusKm, Converter={StaticResource DoubleToStringConverter}}" Keyboard="Numeric" FontSize="13"/>
                            </Border>

                            <Label Grid.Row="2" Text="Heuristic:" Style="{StaticResource FieldText}"/>
                            <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource WinInput}">
                                <Entry Text="{Binding HeuristicMaxSpeedKmH, Converter={StaticResource DoubleToStringConverter}}" Keyboard="Numeric" FontSize="13"/>
                            </Border>

                            <Label Grid.Row="3" Text="Max Offset:" Style="{StaticResource FieldText}"/>
                            <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource WinInput}">
                                <Entry Text="{Binding MaxNearestNodeDistanceKm, Converter={StaticResource DoubleToStringConverter}}" Keyboard="Numeric" FontSize="13"/>
                            </Border>
                        </Grid>

                        <Label Text="* Affects server performance" 
                               FontSize="11" TextColor="Gray" 
                               HorizontalOptions="Center" Margin="0,15,0,0"/>
                    </VerticalStackLayout>
                </Border>

                <Button Grid.Row="1" Grid.ColumnSpan="3"
                        Text="Save Settings"
                        Command="{Binding SaveSettingsCommand}"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                        BackgroundColor="{StaticResource BrandColor}"
                        TextColor="White"
                        FontSize="15"
                        FontAttributes="Bold"
                        CornerRadius="6"
                        HeightRequest="40"
                        WidthRequest="250"
                        HorizontalOptions="Center"
                        Margin="0,30,0,20">

                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="PointerOver">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="{StaticResource BrandColorHover}" />
                                    <Setter Property="Scale" Value="1.02" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>
                </Button>

            </Grid>
        </ScrollView>

        <Grid BackgroundColor="{AppThemeBinding Light=#99FFFFFF, Dark=#AA000000}" 
              IsVisible="{Binding IsLoading}" InputTransparent="False">
            <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#2D2D2D}" 
                    StrokeShape="RoundRectangle 8"
                    StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#DDD, Dark=#444}"
                    HorizontalOptions="Center" VerticalOptions="Center" Padding="30">
                <VerticalStackLayout Spacing="15">
                    <ActivityIndicator IsRunning="True" Color="{StaticResource BrandColor}"/>
                    <Label Text="Saving..." TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>