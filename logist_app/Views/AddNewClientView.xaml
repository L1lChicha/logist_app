<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="logist_app.Views.AddNewClientView"
             Title="Add Client"
             BackgroundColor="#F5F5F5">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="PrimaryColor">#007ACC</Color>
            <Color x:Key="SuccessColor">#1E8E3E</Color>
            <Color x:Key="TextPrimary">#1F1F1F</Color>
            <Color x:Key="TextSecondary">#757575</Color>

            <Style x:Key="InputBorderStyle" TargetType="Border">
                <Setter Property="Stroke" Value="#E0E0E0"/>
                <Setter Property="StrokeThickness" Value="1"/>
                <Setter Property="StrokeShape" Value="RoundRectangle 8"/>
                <Setter Property="BackgroundColor" Value="White"/>
                <Setter Property="Padding" Value="10,0"/>
                <Setter Property="HeightRequest" Value="45"/>
            </Style>

            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="Margin" Value="0,0,0,5"/>
            </Style>

            <Style TargetType="Entry">
                <Setter Property="TextColor" Value="Black"/>
                <Setter Property="PlaceholderColor" Value="#9CA3AF"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="BackgroundColor" Value="Transparent"/>
                <Setter Property="VerticalOptions" Value="Center"/>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid ColumnDefinitions="400, *" RowDefinitions="*">

        <Border Grid.Column="0" 
                BackgroundColor="White" 
                StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="2,0" Radius="10" Opacity="0.05"/>
            </Border.Shadow>

            <ScrollView>
                <VerticalStackLayout Padding="20" Spacing="15">

                    <Label Text="New Client" 
                           FontSize="22" 
                           FontAttributes="Bold" 
                           TextColor="{StaticResource TextPrimary}"
                           Margin="0,0,0,10"/>

                    <VerticalStackLayout Spacing="0">
                        <Label Text="Client Name"/>
                        <Border Style="{StaticResource InputBorderStyle}">
                            <Entry Text="{Binding Name}" Placeholder="Enter client name" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="0">
                        <Label Text="Address"/>
                        <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="5">
                            <Border Grid.Column="0" Style="{StaticResource InputBorderStyle}">
                                <Entry Text="{Binding Address}" Placeholder="Street address" />
                            </Border>

                            <Button Grid.Column="1" 
                                    Clicked="FindButton_Clicked" 
                                    Text="🔍" 
                                    ToolTipProperties.Text="Find on map"
                                    BackgroundColor="#4dd1e3" 
                                    TextColor="White"
                                    HeightRequest="45" WidthRequest="45" 
                                    CornerRadius="8" Padding="0"/>

                            <Button Grid.Column="2" 
                                    Clicked="GetLocationData_Clicked" 
                                    Text="📍"
                                    ToolTipProperties.Text="Use current location"
                                    BackgroundColor="#4dd1e3" 
                                    TextColor="White"
                                    HeightRequest="45" WidthRequest="45" 
                                    CornerRadius="8" Padding="0"/>
                        </Grid>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*, 0.6*" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0" Spacing="0">
                            <Label Text="City"/>
                            <Border Style="{StaticResource InputBorderStyle}">
                                <Entry Text="{Binding City}" Placeholder="City" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="0">
                            <Label Text="Post Code"/>
                            <Border Style="{StaticResource InputBorderStyle}">
                                <Entry Text="{Binding PostalCode}" Placeholder="Index" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <VerticalStackLayout Spacing="0">
                        <Label Text="Contact Info"/>
                        <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                            <Border Grid.Column="0" Style="{StaticResource InputBorderStyle}">
                                <Entry Text="{Binding Phone}" Placeholder="Phone" Keyboard="Telephone"/>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource InputBorderStyle}">
                                <Entry Text="{Binding Email}" Placeholder="Email" Keyboard="Email"/>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="#F0F0F0" Margin="0,5"/>

                    <Label Text="Logistics Details" FontSize="16" Margin="0,5"/>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0" Spacing="0">
                            <Label Text="Containers"/>
                            <Border Style="{StaticResource InputBorderStyle}">
                                <Entry Text="{Binding ContainerCount}" Placeholder="Qty" Keyboard="Numeric"/>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="0">
                            <Label Text="Volume (m³)"/>
                            <Border Style="{StaticResource InputBorderStyle}">
                                <Entry Text="{Binding Volume}" Placeholder="Vol" Keyboard="Numeric"/>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>
                    <VerticalStackLayout>
                        <Label Text="Select loading type"></Label>
                        <Border Style="{StaticResource InputBorderStyle}">
                       
                            <Picker SelectedItem="{Binding LoadingType}" 
                            TextColor="Black"
                            TitleColor="#999"
                            BackgroundColor="Transparent"
                            Margin="0"
                            VerticalOptions="Center" 
                            HorizontalOptions="Fill">           
                            <Picker.ItemsSource>
                                <x:Array Type="{x:Type x:String}">
                                    <x:String>side loading</x:String>
                                    <x:String>rear loading</x:String>
                                    <x:String>lifting with a manipulator</x:String>
                                </x:Array>
                            </Picker.ItemsSource>
                        </Picker>
                        </Border>
                    </VerticalStackLayout>
                    
                    <VerticalStackLayout Spacing="0">
                        <Label Text="Start date"/>
                        <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                            <Border Grid.Column="0" Style="{StaticResource InputBorderStyle}">
                                <DatePicker Date="{Binding StartDate}" TextColor="Black"/>
                            </Border>

                            <Button Grid.Column="1"
                                    Text="Recurrence" 
                                    Clicked="OnRecurrenceConfigClicked" 
                                    BackgroundColor="#646464" 
                                    TextColor="White"
                                    CornerRadius="8"
                                    HeightRequest="45"/>
                        </Grid>
                        <Label Text="{Binding RecurrenceSummary}" 
                               TextColor="{StaticResource TextSecondary}" 
                               FontSize="11" 
                               Margin="2,2,0,0"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="10" Margin="0,20,0,20">
                        <Button Text="Add Point" 
                                Command="{Binding SubmitCommand}" 
                                BackgroundColor="{StaticResource SuccessColor}" 
                                TextColor="White"
                                HeightRequest="50"
                                CornerRadius="10"
                                FontAttributes="Bold"
                                FontSize="16"/>

                        <Button Text="View Data" 
                                Clicked="OnViewDataClicked" 
                                BackgroundColor="White" 
                                TextColor="{StaticResource TextPrimary}"
                                BorderColor="#E0E0E0"
                                BorderWidth="1"
                                HeightRequest="45"
                                CornerRadius="10"
                                FontSize="14"/>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>
        </Border>

        <Border Grid.Column="1" 
                Margin="20" 
                StrokeShape="RoundRectangle 20" 
                StrokeThickness="0"
                BackgroundColor="White">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="15" Opacity="0.1"/>
            </Border.Shadow>

            <WebView x:Name="MapWebView" 
                     Source="map.html" 
                     HorizontalOptions="Fill" 
                     VerticalOptions="Fill"/>
        </Border>

    </Grid>
</ContentPage>