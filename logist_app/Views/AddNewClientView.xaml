<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="logist_app.MainPage"
             Padding="0"
             Title="Adding client">
    
    <ContentPage.Resources>
        <Style TargetType="Label">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextColor" Value="Black" />
            <Setter Property="VerticalOptions" Value="Center" />
            <Setter Property="Margin" Value="2,10,0,5"></Setter>
        </Style>
        <Style TargetType="Entry">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="HeightRequest" Value="32" />
            <Setter Property="VerticalOptions" Value="Center" />
            <Setter Property="PlaceholderColor" Value="#646464" />
            <Setter Property="Background" Value="#D9D9D9"></Setter>
            <Setter Property="Margin" Value="0,0,10,0"></Setter>
            <Setter Property="TextColor" Value="Black"></Setter>

        </Style>
        <Style TargetType="Picker">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="HeightRequest" Value="32" />
            <Setter Property="VerticalOptions" Value="Center" />
            <Setter Property="Background" Value="#D9D9D9"></Setter>
            <Setter Property="BackgroundColor" Value="#D9D9D9"></Setter>
            <Setter Property="TextColor" Value="Black" />
            <Setter Property="Margin" Value="0,0,10,0"></Setter>

        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="HeightRequest" Value="32" />
            <Setter Property="VerticalOptions" Value="Center" />
            <Setter Property="Background" Value="#D9D9D9"></Setter>
            <Setter Property="TextColor" Value="Black" />
            <Setter Property="BackgroundColor" Value="#D9D9D9"></Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="HeightRequest" Value="32" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="BackgroundColor" Value="#008B09"/>
            <Setter Property="WidthRequest" Value="300"/>
            <Setter Property="Margin" Value="0,10,0,0"></Setter>
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="HeightRequest" Value="40"/>

        </Style>
        <Style TargetType="StackLayout">
            <Setter Property="Margin" Value="5,0,0,0"></Setter>
        </Style>
        <Style TargetType="WebView">
            <Setter Property="WidthRequest" Value="820" />
        </Style>
    </ContentPage.Resources>
    
    <StackLayout Orientation="Horizontal" BackgroundColor="White">
        <StackLayout Orientation="Vertical" WidthRequest="700">
            <StackLayout Orientation="Vertical">
                <Label Text="Name"/>
                <Entry x:Name="NameEntry" Placeholder="Имя" />
            </StackLayout>
         
                <StackLayout  Orientation="Vertical">
                    <Label Text="Address"/>
                </StackLayout>
            <StackLayout Orientation="Horizontal">
                <Entry x:Name="AddressEntry" Placeholder="Адрес" WidthRequest="480" Margin="0,0,5,0"/>
                <Button Clicked="FindButton" Text="Find" HeightRequest="32" WidthRequest="100"  CornerRadius="5" BackgroundColor="#4dd1e3" Margin="0,0,0,0"></Button>
                <Button Clicked="GetLocationData" Text="Set location" HeightRequest="32" WidthRequest="100" CornerRadius="5" BackgroundColor="#4dd1e3" Margin="0,0,0,0"></Button>
            </StackLayout>
            <StackLayout Orientation="Vertical">
                <Label Text="City" />
                <Entry x:Name="CityEntry" Placeholder="Город"/>
            </StackLayout>
            <StackLayout Orientation="Vertical">
                <Label Text="Post code" />
                <Entry x:Name="PostalCodeEntry" Placeholder="Индекс"/>
            </StackLayout>
            <StackLayout Orientation="Vertical">
                <Label Text="Phone number" />
                <Entry x:Name="PhoneEntry" Placeholder="Телефон" />
            </StackLayout>
            <StackLayout Orientation="Vertical">
                <Label Text="Email" />
                <Entry x:Name="EmailEntry" Placeholder="Email"/>
            </StackLayout>
            <StackLayout Orientation="Vertical">
                <Label Text="Reccurence" />
                <Picker x:Name="RecurrencePicker" >
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>weekly</x:String>
                            <x:String>monthly</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>
            </StackLayout>
            <StackLayout  Orientation="Vertical">
                <Label Text="Numbers of containers" />
                <Entry x:Name="ContainerCountEntry" Placeholder="Количество" Keyboard="Numeric" />
            </StackLayout>
            <StackLayout  Orientation="Vertical" HorizontalOptions="Start" >
                <Label Text="Volume"/>
                <Entry x:Name="VolumeEntry"  WidthRequest="150"/>
            </StackLayout>
            <StackLayout  Orientation="Vertical">
                <Label Text="Type of load" />
                <Picker x:Name="LoadingTypePicker" >
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>Default</x:String>
                            <x:String>Lifting with a manipulator</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>
            </StackLayout>
            
            <StackLayout  Orientation="Vertical" HorizontalOptions="Start" >
                <Label Text="Date"/>
                <DatePicker x:Name="StartDatePicker"  WidthRequest="150"/>
            </StackLayout>
            <StackLayout Orientation="Vertical">
                <Button Text="Add point" Clicked="OnSubmitClicked" HorizontalOptions="Center" />
                <Button Text="View data" Clicked="OnViewDataClicked"  HorizontalOptions="Center" />
            </StackLayout>
        </StackLayout>
        <WebView x:Name="MapWebView"   Source="map.html" />
    </StackLayout>
</ContentPage>