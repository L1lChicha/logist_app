<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="logist_app.Views.AddNewClientView"
             Title="Add Client"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1a1a1a}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="PrimaryColor">#007ACC</Color>
            <Color x:Key="PrimaryColorDark">#5AAFFF</Color>
            <Color x:Key="SuccessColor">#1E8E3E</Color>
            <Color x:Key="SuccessColorDark">#4ADE80</Color>

            <Style x:Key="InputBorderStyle" TargetType="Border">
                <Setter Property="Stroke" Value="{AppThemeBinding Light=#E0E0E0, Dark=#404040}"/>
                <Setter Property="StrokeThickness" Value="1"/>
                <Setter Property="StrokeShape" Value="RoundRectangle 8"/>
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=White, Dark=#2d2d2d}"/>
                <Setter Property="Padding" Value="10,0"/>
                <Setter Property="HeightRequest" Value="45"/>
            </Style>

            <Style x:Key="FormLabelStyle" TargetType="Label">
                <Setter Property="TextColor" Value="{AppThemeBinding Light=#1F1F1F, Dark=#E0E0E0}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="Margin" Value="0,0,0,5"/>
            </Style>

            <Style x:Key="FormEntryStyle" TargetType="Entry">
                <Setter Property="TextColor" Value="{AppThemeBinding Light=Black, Dark=#E0E0E0}"/>
                <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light=#9CA3AF, Dark=#666}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="BackgroundColor" Value="Transparent"/>
                <Setter Property="VerticalOptions" Value="Center"/>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid ColumnDefinitions="400, *" RowDefinitions="*">

        <Border Grid.Column="0" 
                BackgroundColor="{AppThemeBinding Light=White, Dark=#2d2d2d}" 
                StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="2,0" Radius="10" Opacity="{AppThemeBinding Light=0.05, Dark=0.2}"/>
            </Border.Shadow>

            <ScrollView>
                <VerticalStackLayout Padding="20" Spacing="15">

                    <Label Text="New Client" 
                           FontSize="22" 
                           FontAttributes="Bold" 
                           TextColor="{AppThemeBinding Light=#1F1F1F, Dark=#E0E0E0}"
                           Margin="0,0,0,10"/>

                    <VerticalStackLayout Spacing="0">
                        <Label Text="Client Name" Style="{StaticResource FormLabelStyle}"/>
                        <Border Style="{StaticResource InputBorderStyle}">
                            <Entry Text="{Binding Name}" Placeholder="Enter client name" Style="{StaticResource FormEntryStyle}"/>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="0">
                        <Label Text="Address" Style="{StaticResource FormLabelStyle}"/>
                        <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="5">
                            <Border Grid.Column="0" Style="{StaticResource InputBorderStyle}">
                                <Entry Text="{Binding Address}" Placeholder="Street address" Style="{StaticResource FormEntryStyle}"/>
                            </Border>

                            <Button Grid.Column="1" 
                                    Clicked="FindButton_Clicked" 
                                    Text="🔍" 
                                    ToolTipProperties.Text="Find on map"
                                    BackgroundColor="#4dd1e3" 
                                    TextColor="White"
                                    HeightRequest="45" WidthRequest="45" 
                                    CornerRadius="8" Padding="0"/>

                            <Button Grid.Column="2" 
                                    Clicked="GetLocationData_Clicked" 
                                    Text="📍"
                                    ToolTipProperties.Text="Use current location"
                                    BackgroundColor="#4dd1e3" 
                                    TextColor="White"
                                    HeightRequest="45" WidthRequest="45" 
                                    CornerRadius="8" Padding="0"/>
                        </Grid>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*, 0.6*" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0" Spacing="0">
                            <Label Text="City" Style="{StaticResource FormLabelStyle}"/>
                            <Border Style="{StaticResource InputBorderStyle}">
                                <Entry Text="{Binding City}" Placeholder="City" Style="{StaticResource FormEntryStyle}"/>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="0">
                            <Label Text="Post Code" Style="{StaticResource FormLabelStyle}"/>
                            <Border Style="{StaticResource InputBorderStyle}">
                                <Entry Text="{Binding PostalCode}" Placeholder="Index" Style="{StaticResource FormEntryStyle}"/>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <VerticalStackLayout Spacing="0">
                        <Label Text="Contact Info" Style="{StaticResource FormLabelStyle}"/>
                        <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                            <Border Grid.Column="0" Style="{StaticResource InputBorderStyle}">
                                <Entry Text="{Binding Phone}" Placeholder="Phone" Keyboard="Telephone" Style="{StaticResource FormEntryStyle}"/>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource InputBorderStyle}">
                                <Entry Text="{Binding Email}" Placeholder="Email" Keyboard="Email" Style="{StaticResource FormEntryStyle}"/>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#F0F0F0, Dark=#404040}" Margin="0,5"/>

                    <Label Text="Logistics Details" FontSize="16" Style="{StaticResource FormLabelStyle}" Margin="0,5"/>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0" Spacing="0">
                            <Label Text="Containers" Style="{StaticResource FormLabelStyle}"/>
                            <Border Style="{StaticResource InputBorderStyle}">
                                <Entry Text="{Binding ContainerCount}" Placeholder="Qty" Keyboard="Numeric" Style="{StaticResource FormEntryStyle}"/>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="0">
                            <Label Text="Volume (m³)" Style="{StaticResource FormLabelStyle}"/>
                            <Border Style="{StaticResource InputBorderStyle}">
                                <Entry Text="{Binding Volume}" Placeholder="Vol" Keyboard="Numeric" Style="{StaticResource FormEntryStyle}"/>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>
                    <VerticalStackLayout>
                        <Label Text="Select loading type" Style="{StaticResource FormLabelStyle}"/>
                        <Border Style="{StaticResource InputBorderStyle}">
                            <Picker SelectedItem="{Binding LoadingType}" 
                                    TextColor="{AppThemeBinding Light=Black, Dark=#E0E0E0}"
                                    TitleColor="{AppThemeBinding Light=#999, Dark=#666}"
                                    BackgroundColor="Transparent"
                                    Margin="0"
                                    VerticalOptions="Center" 
                                    HorizontalOptions="Fill">           
                                <Picker.ItemsSource>
                                    <x:Array Type="{x:Type x:String}">
                                        <x:String>side loading</x:String>
                                        <x:String>rear loading</x:String>
                                        <x:String>lifting with a manipulator</x:String>
                                    </x:Array>
                                </Picker.ItemsSource>
                            </Picker>
                        </Border>
                    </VerticalStackLayout>
                    
                    <VerticalStackLayout Spacing="0">
                        <Label Text="Start date" Style="{StaticResource FormLabelStyle}"/>
                        <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                            <Border Grid.Column="0" Style="{StaticResource InputBorderStyle}">
                                <DatePicker Date="{Binding StartDate}" TextColor="{AppThemeBinding Light=Black, Dark=#E0E0E0}"/>
                            </Border>

                            <Button Grid.Column="1"
                                    Text="Recurrence" 
                                    Clicked="OnRecurrenceConfigClicked" 
                                    BackgroundColor="{AppThemeBinding Light=#646464, Dark=#505050}" 
                                    TextColor="White"
                                    CornerRadius="8"
                                    HeightRequest="45"/>
                        </Grid>
                        <Label Text="{Binding RecurrenceSummary}" 
                               TextColor="{AppThemeBinding Light=#757575, Dark=#888888}" 
                               FontSize="11" 
                               Margin="2,2,0,0"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="10" Margin="0,20,0,20">
                        <Button Text="Add Point" 
                                Command="{Binding SubmitCommand}" 
                                BackgroundColor="{AppThemeBinding Light={StaticResource SuccessColor}, Dark={StaticResource SuccessColorDark}}" 
                                TextColor="{AppThemeBinding Light=White, Dark=#1a1a1a}"
                                HeightRequest="50"
                                CornerRadius="10"
                                FontAttributes="Bold"
                                FontSize="16"/>

                        <Button Text="View Data" 
                                Clicked="OnViewDataClicked" 
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#2d2d2d}" 
                                TextColor="{AppThemeBinding Light=#1F1F1F, Dark=#E0E0E0}"
                                BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#404040}"
                                BorderWidth="1"
                                HeightRequest="45"
                                CornerRadius="10"
                                FontSize="14"/>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>
        </Border>

        <Border Grid.Column="1" 
                Margin="20" 
                StrokeShape="RoundRectangle 20" 
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#2d2d2d}">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="15" Opacity="{AppThemeBinding Light=0.1, Dark=0.3}"/>
            </Border.Shadow>

            <WebView x:Name="MapWebView" 
                     Source="map.html" 
                     HorizontalOptions="Fill" 
                     VerticalOptions="Fill"/>
        </Border>

    </Grid>
</ContentPage>
