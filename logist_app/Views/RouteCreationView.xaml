<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="logist_app.Views.RouteCreationView"
             xmlns:viewmodels="clr-namespace:logist_app.ViewModels"
             Title="Create Route"
             BackgroundColor="#F5F5F5">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="PrimaryColor">#007ACC</Color>
            <Color x:Key="SuccessColor">#1E8E3E</Color>
            <Color x:Key="CardBackground">White</Color>
            <Color x:Key="TextPrimary">#1F1F1F</Color>
            <Color x:Key="TextSecondary">#757575</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, Auto, Auto, *" 
          ColumnDefinitions="*"
          Padding="15"
          RowSpacing="15">

        <Grid Grid.Row="0" ColumnDefinitions="*, Auto, Auto" ColumnSpacing="10">

            <Label Text="Select Clients" 
                   FontSize="22" 
                   FontAttributes="Bold" 
                   TextColor="{StaticResource TextPrimary}"
                   VerticalOptions="Center"/>

            <Button Grid.Column="1"
                    Text="Refresh"
                    Command="{Binding RefreshCommand}"
                    BackgroundColor="White"
                    TextColor="{StaticResource PrimaryColor}"
                    BorderColor="{StaticResource PrimaryColor}"
                    BorderWidth="1"
                    CornerRadius="8"
                    HeightRequest="40"
                    Padding="15,0"
                    FontAttributes="Bold"/>

            <Button Grid.Column="2"
                    Text="Create Route"
                    Command="{Binding CreateRouteCommand}"
                    IsEnabled="{Binding IsCreateButtonEnabled}"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="40"
                    Padding="20,0"
                    FontAttributes="Bold">
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding IsCreateButtonEnabled}" Value="True">
                        <Setter Property="BackgroundColor" Value="{StaticResource SuccessColor}" />
                    </DataTrigger>
                    <DataTrigger TargetType="Button" Binding="{Binding IsCreateButtonEnabled}" Value="False">
                        <Setter Property="BackgroundColor" Value="#BDBDBD" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>
        </Grid>

        <Border Grid.Row="1" 
                StrokeShape="RoundRectangle 10" 
                StrokeThickness="0" 
                BackgroundColor="White" 
                Padding="5">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.05"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="*, Auto, Auto">
                <SearchBar Grid.Column="0"
                           Placeholder="Search clients..."
                           Text="{Binding FilterText, Mode=TwoWay}"
                           BackgroundColor="Transparent"
                           TextColor="Black"/>


                <HorizontalStackLayout Grid.Column="2" Spacing="5" Padding="10,0" VerticalOptions="Center">
                    <Label Text="Sort by:" TextColor="{StaticResource TextPrimary}" FontSize="16" VerticalOptions="Center"/>
                    <Picker Title=""
                            TextColor="{StaticResource PrimaryColor}"
                            TitleColor="{StaticResource TextSecondary}"
                            ItemsSource="{Binding PickerOptions}"
                            SelectedIndex="{Binding SelectedOptionIndex, Mode=TwoWay}"
                            WidthRequest="200"/>
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding SelectedClientsCollection}"
                        HeightRequest="40"
                        IsVisible="{Binding SelectedClientsCollection.Count, Converter={toolkit:IntToBoolConverter}}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="viewmodels:SelectableClient">
                    <Border StrokeShape="RoundRectangle 20"
                            BackgroundColor="#E6F4EA"
                            Stroke="{StaticResource SuccessColor}"
                            StrokeThickness="1"
                            Padding="12,0"
                            HeightRequest="32">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:RouteCreationViewModel}}, Path=ToggleSelectionCommand}"
                                                  CommandParameter="{Binding}" />
                        </Border.GestureRecognizers>

                        <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                            <Label Text="{Binding Name}" TextColor="{StaticResource SuccessColor}" FontSize="13" FontAttributes="Bold"/>
                            <Label Text="✕" TextColor="{StaticResource SuccessColor}" FontSize="12" FontAttributes="Bold"/>
                        </HorizontalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <RefreshView Grid.Row="3" Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding Clients}"
                            SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="1" VerticalItemSpacing="10"/>
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:SelectableClient">
                        <Border StrokeShape="RoundRectangle 12"
                                StrokeThickness="1"
                                Padding="15">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:RouteCreationViewModel}}, Path=ToggleSelectionCommand}"
                                                      CommandParameter="{Binding}" />
                            </Border.GestureRecognizers>

                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BackgroundColor" Value="White" />
                                    <Setter Property="Stroke" Value="Transparent" />
                                    <Setter Property="Shadow">
                                        <Setter.Value>
                                            <Shadow Brush="Black" Offset="0,2" Radius="3" Opacity="0.05"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BackgroundColor" Value="#F0FDF4" />
                                            <Setter Property="Stroke" Value="{StaticResource SuccessColor}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, Auto" RowSpacing="5">

                                <Label Grid.Row="0" Grid.Column="0" 
                                       Text="{Binding Name}" 
                                       FontSize="16" 
                                       FontAttributes="Bold" 
                                       TextColor="{StaticResource TextPrimary}"/>

                                <Label Grid.Row="0" Grid.Column="1" 
                                       Text="✓" 
                                       TextColor="{StaticResource SuccessColor}" 
                                       FontSize="20" 
                                       FontAttributes="Bold"
                                       IsVisible="{Binding IsSelected}"/>

                                <VerticalStackLayout Grid.Row="1" Grid.ColumnSpan="2" Spacing="2">

                                    <Label Text="{Binding Address, StringFormat='Address: {0}'}" FontSize="13" TextColor="{StaticResource TextPrimary}"/>

                                    <HorizontalStackLayout Spacing="10">
                                        <Label Text="{Binding City}" FontSize="15" TextColor="{StaticResource TextPrimary}"/>
                                        <Label Text="•" TextColor="#DDD"/>
                                        <Label Text="{Binding Phone, StringFormat='Phone: {0}'}" FontSize="13" TextColor="{StaticResource TextPrimary}"/>
                                    </HorizontalStackLayout>

                                    <Label Text="{Binding StartDate, StringFormat='Start date: {0:MMM dd, yyyy}'}" 
                                           FontSize="14"
                                           TextColor="{StaticResource TextPrimary}"
                                           Margin="0,5,0,0"/>
                                </VerticalStackLayout>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>