<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:model="clr-namespace:logist_app.Core.Entities"
             xmlns:vm="clr-namespace:logist_app.ViewModels"
             x:Class="logist_app.Views.VehiclesDataView"
             Title="Vehicles"
             BackgroundColor="#F5F5F5">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="PrimaryColor">#007ACC</Color>
            <Color x:Key="DestructiveColor">#D93025</Color>
            <Color x:Key="SuccessColor">#1E8E3E</Color>
            <Color x:Key="TextPrimary">#1F1F1F</Color>
            <Color x:Key="TextSecondary">#757575</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *" Padding="15" RowSpacing="15">

        <Grid Grid.Row="0" ColumnDefinitions="*, Auto, Auto, Auto" ColumnSpacing="10">

            <Label Text="Fleet Management" 
                   FontSize="22" 
                   FontAttributes="Bold" 
                   VerticalOptions="Center"
                   TextColor="{StaticResource TextPrimary}"/>

            <Button Grid.Column="1"
                    Text="🔄"
                    Command="{Binding RefreshCommand}"
                    BackgroundColor="White"
                    TextColor="{StaticResource PrimaryColor}"
                    BorderColor="#E0E0E0"
                    BorderWidth="1"
                    HeightRequest="40"
                    WidthRequest="45"
                    CornerRadius="8"
                    Padding="0"/>

            <Button Grid.Column="2"
                    Text="🗑"
                    Command="{Binding DeleteCommand}"
                    BackgroundColor="#FCE8E6"
                    TextColor="{StaticResource DestructiveColor}"
                    HeightRequest="40"
                    WidthRequest="45"
                    CornerRadius="8"
                    Padding="0"/>

            <Button Grid.Column="3"
                    Text="➕ Add Vehicle"
                    Command="{Binding AddVehicleCommand}"
                    BackgroundColor="{StaticResource PrimaryColor}"
                    TextColor="White"
                    HeightRequest="40"
                    CornerRadius="8"
                    Padding="15,0"
                    FontAttributes="Bold"/>
        </Grid>

        <RefreshView Grid.Row="1" Command="{Binding RefreshCommand}">
            <CollectionView x:Name="VehiclesCollectionView"
                            ItemsSource="{Binding Vehicles}"
                            SelectedItem="{Binding SelectedVehicle, Mode=TwoWay}"
                            SelectionMode="Single">

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="12"/>
                </CollectionView.ItemsLayout>

                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10">
                        <Label Text="🚚" FontSize="40" HorizontalOptions="Center"/>
                        <Label Text="No vehicles found" TextColor="{StaticResource TextSecondary}" FontSize="16"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:Vehicle">
                        <Border StrokeShape="RoundRectangle 12"
                                StrokeThickness="1"
                                Margin="2">

                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Radius="3" Opacity="0.05"/>
                            </Border.Shadow>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:VehiclesDataViewModel}}, Path=ToggleSelectionCommand}"
                                                      CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup Name="CommonStates">
                                    <VisualState Name="Normal">
                                        <VisualState.Setters>
                                            <Setter Property="BackgroundColor" Value="White"/>
                                            <Setter Property="Stroke" Value="Transparent"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState Name="Selected">
                                        <VisualState.Setters>
                                            <Setter Property="Stroke" Value="{StaticResource PrimaryColor}" />
                                            <Setter Property="StrokeThickness" Value="2" />
                                            <Setter Property="BackgroundColor" Value="#EDF7FF" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <Grid RowDefinitions="Auto, Auto, Auto" RowSpacing="10" Padding="15">

                                <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="0">
                                        <Label Text="{Binding Model}" 
                                               FontSize="18" 
                                               FontAttributes="Bold" 
                                               TextColor="{StaticResource TextPrimary}"/>
                                        <Label Text="{Binding Id, StringFormat='ID: #{0}'}" 
                                               FontSize="11" 
                                               TextColor="{StaticResource TextSecondary}"/>
                                    </VerticalStackLayout>

                                    <Border Grid.Column="1" 
                                            Stroke="#333" 
                                            StrokeThickness="1" 
                                            StrokeShape="RoundRectangle 4" 
                                            BackgroundColor="#FFD700" 
                                            Padding="8,2"
                                            VerticalOptions="Start">
                                        <Label Text="{Binding LicensePlate}" 
                                               TextColor="Black" 
                                               FontAttributes="Bold" 
                                               FontSize="13"/>
                                    </Border>
                                </Grid>

                                <Grid Grid.Row="1" ColumnDefinitions="*, *, *" ColumnSpacing="5">
                                    <VerticalStackLayout Grid.Column="0">
                                        <Label Text="Capacity" FontSize="11" TextColor="{StaticResource TextSecondary}"/>
                                        <Label Text="{Binding Capacity}" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}"/>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Column="1">
                                        <Label Text="Tonnage" FontSize="11" TextColor="{StaticResource TextSecondary}"/>
                                        <Label Text="{Binding Tonnage, StringFormat='{0} t'}" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}"/>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Column="2">
                                        <Label Text="Type" FontSize="11" TextColor="{StaticResource TextSecondary}"/>
                                        <Label Text="{Binding LoadingType}" FontSize="13" TextColor="{StaticResource TextPrimary}" LineBreakMode="TailTruncation"/>
                                    </VerticalStackLayout>
                                </Grid>

                                <BoxView Grid.Row="2" HeightRequest="1" Color="#F0F0F0" VerticalOptions="Start"/>

                                <Grid Grid.Row="2" ColumnDefinitions="*, Auto" Margin="0,5,0,0">
                                    <Label Grid.Column="0" 
                                           Text="{Binding CreatedAt, StringFormat='Added: {0:MMM dd, yyyy}'}" 
                                           FontSize="12" 
                                           TextColor="{StaticResource TextSecondary}"
                                           VerticalOptions="Center"/>

                                    <Label Grid.Column="1" 
                                           Text="{Binding DistributionStatus, StringFormat='● {0}'}" 
                                           FontSize="13" 
                                           FontAttributes="Bold"
                                           VerticalOptions="Center">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding DistributionStatus}" Value="not distributed">
                                                <Setter Property="TextColor" Value="{StaticResource SuccessColor}"/>
                                                <Setter Property="Text" Value="● Available"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding DistributionStatus}" Value="distributed">
                                                <Setter Property="TextColor" Value="{StaticResource DestructiveColor}"/>
                                                <Setter Property="Text" Value="● Busy"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding DistributionStatus}" Value="{x:Null}">
                                                <Setter Property="TextColor" Value="Gray"/>
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Grid>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>