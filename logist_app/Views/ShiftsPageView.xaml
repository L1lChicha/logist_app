<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:logist_app.ViewModels"
             xmlns:models="clr-namespace:logist_app.Models"
             x:Class="logist_app.Views.ShiftsPageView"
             Title="Today's Shifts"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1a1a1a}">



    <Grid RowDefinitions="Auto, *">

        <Button Grid.Row="0" 
            Text="🔄 Обновить список" 
            Command="{Binding LoadShiftsCommand}" 
            Margin="10,10,10,0" 
            BackgroundColor="#2196F3" 
            TextColor="White" 
            FontAttributes="Bold" 
            CornerRadius="8"/>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Shifts}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 10" Padding="15" Margin="10">
                        <VerticalStackLayout Spacing="10">

                            <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="18"/>
                            <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto" ColumnSpacing="10">
                                <Label Grid.Row="0" Grid.Column="0" Text="{Binding VehicleId, StringFormat='Машина: {0}'}"/>
                                <Label Grid.Row="0" Grid.Column="1" Text="{Binding AppointedDate, StringFormat='Дата: {0:dd.MM.yyyy}'}"/>
                                <Label Grid.Row="1" Grid.Column="0" Text="{Binding DisplayDuration, StringFormat='Время: {0}'}"/>
                                <Label Grid.Row="1" Grid.Column="1" Text="{Binding DisplayDistance, StringFormat='Расстояние: {0:F1}'}"/>
                            </Grid>

                            <BoxView HeightRequest="1" Color="LightGray" Margin="0,10"/>
                            <Label Text="Маршруты смены:" FontAttributes="Bold" TextColor="Gray"/>

                            <CollectionView ItemsSource="{Binding RoutesId}"
                            SelectionMode="Single"
                            SelectedItem="{Binding BindingContext.SelectedRoute, Source={RelativeSource AncestorType={x:Type ContentPage}}}">

                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10" Margin="0,0,0,8" BackgroundColor="#F9F9F9" Stroke="Black">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="12" />
                                            </Border.StrokeShape>
                                            <Grid ColumnDefinitions="*, Auto">
                                                <Label Grid.Column="0" Text="{Binding Name}" VerticalOptions="Center"/>

                                                <HorizontalStackLayout Grid.Column="1" HorizontalOptions="End">
                                                    <VerticalStackLayout Margin="0,0,50,0">
                                                        <Label Text="{Binding Statistics.BigContainerQuantity, StringFormat='Кол-во заглубленных контейнеров: {0}'}" FontSize="12"/>
                                                        <Label Text="{Binding Statistics.StandardContainerQuantity, StringFormat='Кол-во стандартных контейнеров: {0}'}" FontSize="12"/>
                                                    </VerticalStackLayout>
                                                    <VerticalStackLayout Margin="0,0,50,0">
                                                        <Label Text="{Binding DisplayTonnage, StringFormat='Тоннаж: {0}'}" HorizontalOptions="Start" FontSize="12"></Label>
                                                        <Label Text="{Binding DisplayVolume, StringFormat='Объем: {0}'}" HorizontalOptions="Start" FontSize="12"></Label>
                                                    </VerticalStackLayout>
                                                    <VerticalStackLayout>
                                                        <Label Text="{Binding DisplayDistance}" FontSize="12" HorizontalOptions="End"/>
                                                        <Label Text="{Binding DisplayDuration}" FontSize="12" HorizontalOptions="End"/>
                                                        <Label Text="{Binding Status}" FontSize="12" TextColor="Gray" HorizontalOptions="End"/>
                                                    </VerticalStackLayout>
                                                    
                                                </HorizontalStackLayout>
                                            </Grid>

                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
    