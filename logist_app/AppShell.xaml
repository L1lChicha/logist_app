<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="logist_app.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:logist_app.Views"
    xmlns:views="clr-namespace:logist_app.Views"
    Title="EcoLogistics"
    Shell.NavBarIsVisible="False">


    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate views:LoginPageView}"
        Route="LoginPageView"
        Shell.FlyoutItemIsVisible="False" />

    <TabBar Route="Main">

        <ShellContent
        Route="ActionPageView" 
        ContentTemplate="{DataTemplate views:ActionPageView}" />

    </TabBar>

    <Shell.ToolbarItems>
        <ToolbarItem Text="⚙️"
                     Order="Primary"
                     Priority="1"
                     Clicked="OnSettingsClicked" />
        <ToolbarItem Text="🔔"
                     Order="Primary"
                     Priority="0"
                     Clicked="OnNotificationsClicked" />
    </Shell.ToolbarItems>

</Shell>




